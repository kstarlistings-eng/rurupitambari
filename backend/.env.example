NODE_ENV=development
PORT=5000

# Local / Docker PostgreSQL
DATABASE_URL=postgresql://pitambari:pitambari@localhost:5432/pitambari

# Supabase PostgreSQL (use the connection string from Supabase Dashboard → Project Settings → Database)
# The URL below uses the Supabase connection pooler (recommended for serverless / Render):
# DATABASE_URL=postgresql://postgres.owwuhsqyskydngwowpyy:[YOUR-PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres

# Your deployed frontend URL (required in production so CORS can be restricted)
# FRONTEND_URL=https://your-app.vercel.app

JWT_ACCESS_SECRET=change-this-to-a-very-long-random-secret-key
JWT_REFRESH_SECRET=change-this-to-another-very-long-random-secret-key
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
